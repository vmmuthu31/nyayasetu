generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  REVIEWER
  DEPT_USER
}

enum CaseStatus {
  PENDING_REVIEW
  VERIFIED
  ACTIONED
  APPEALED
  REJECTED
}

enum ActionType {
  COMPLY
  APPEAL
  INFORM
  MONITOR
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  role        UserRole  @default(REVIEWER)
  department  String?
  designation String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reviews     CaseAction[]
  auditLogs   AuditLog[]
}

model Case {
  id              String     @id @default(cuid())
  caseNumber      String     @unique
  court           String
  petitioners     String
  respondents     String
  judgmentDate    DateTime?
  filedAt         DateTime   @default(now())
  status          CaseStatus @default(PENDING_REVIEW)

  pdfStorageKey   String?
  extractedText   String?
  highlights      Json?

  confidenceScore Float      @default(0)
  fingerprint     String?

  actions         CaseAction[]
  auditLogs       AuditLog[]
  directives      Directive[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Directive {
  id              String     @id @default(cuid())
  caseId          String
  case            Case       @relation(fields: [caseId], references: [id])

  text            String
  pageNumber      Int?
  highlightCoords Json?

  actionType      ActionType
  department      String
  deadline        DateTime?
  confidenceScore Float      @default(0)
  fingerprint     String

  isAmbiguous     Boolean    @default(false)
  ambiguityReason String?

  status          CaseStatus @default(PENDING_REVIEW)
  reviewedBy      String?
  reviewedAt      DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model CaseAction {
  id           String     @id @default(cuid())
  caseId       String
  case         Case       @relation(fields: [caseId], references: [id])

  userId       String
  user         User       @relation(fields: [userId], references: [id])

  actionType   String
  notes        String?
  previousData Json?
  newData      Json?

  createdAt    DateTime   @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id])

  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  event        String
  details      Json?

  hash         String   @unique
  prevHash     String
  sequence     Int

  createdAt    DateTime @default(now())
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  email     String?
  createdAt DateTime @default(now())
}
